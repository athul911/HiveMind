# ---- Service ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---- Persistence ----
DATABASE_URL=postgresql+asyncpg://hivemind:hivemind@localhost:5432/hivemind
# Least-privilege read-only role used by the SQL tool (defense in depth).
SQL_TOOL_DATABASE_URL=postgresql+asyncpg://hivemind_ro:hivemind_ro@localhost:5432/hivemind
SQL_TOOL_STATEMENT_TIMEOUT_MS=10000
SQL_TOOL_MAX_ROWS=1000
SQL_TOOL_ALLOWED_SCHEMAS=public

# ---- Broker / cache ----
RABBITMQ_URL=amqp://hivemind:hivemind@localhost:5672/
REDIS_URL=redis://localhost:6379/0

# ---- Auth ----
JWT_SECRET=hivemind-local-dev-secret-change-me-in-prod
JWT_ALGORITHM=HS256
# Set to use OAuth2 JWKS/RS256 instead of the shared secret:
# OAUTH2_JWKS_URL=https://your-idp/.well-known/jwks.json
AUTH_DISABLED=false
RATE_LIMIT_PER_MINUTE=120

# ---- Artifacts ----
ARTIFACT_BASE_PATH=/data/artifacts
# Public base URL used to build owner-authenticated download links (no trailing slash).
PUBLIC_BASE_URL=http://localhost:8000

# ---- Sandbox (code_exec) ----
# docker = container-per-exec (production). subprocess = weaker fallback (laptops/CI).
SANDBOX_BACKEND=docker
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_S=30

# ---- LLM providers ----
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# ---- Orchestration ----
WORKFLOW_ASYNC_THRESHOLD_STEPS=3
SUPERVISOR_MAX_ITERATIONS=12
SUPERVISOR_TOKEN_BUDGET=200000          # cumulative per-conversation token ceiling
EPHEMERAL_AGENT_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=300
SUBAGENT_MAX_DEPTH=2                     # max spawn_subagent recursion depth
CONVERSATION_LOCK_STALE_SECONDS=900      # auto-release a conversation lock held this long

# ---- Conversation memory ----
CONVERSATION_HISTORY_LIMIT=40           # turns kept verbatim before compaction
CONVERSATION_COMPACTION_ENABLED=true

# ---- LLM resilience ----
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_S=0.5
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_S=30
PROMPT_CACHE_ENABLED=true               # Anthropic prompt caching on stable prefixes

# ---- AuthZ / CORS ----
RBAC_ENABLED=false                      # when true, agent mgmt requires ADMIN_SCOPE
ADMIN_SCOPE=hivemind:admin
CORS_ALLOW_ORIGINS=*

# ---- Skills ----
SKILLS_DIR=skills

# ---- Observability ----
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
